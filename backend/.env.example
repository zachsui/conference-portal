# Copy this file to backend/.env and fill in your values.
# .env is git-ignored — never commit secrets.

# Resend API key from https://resend.com/api-keys
# If unset, the API still works — emails are logged to stdout instead of sent.
RESEND_API_KEY=

# From header. The Resend onboarding sender works without a verified domain
# but can ONLY deliver to the email registered on your Resend account.
# To send to anyone, verify your own domain in Resend → Domains and use it here.
RESEND_FROM=Atlas Conference <onboarding@resend.dev>

# Optional: where users should reply to. Leave blank to disable Reply-To.
RESEND_REPLY_TO=

# Public URL of the frontend, used in email links (no trailing slash).
APP_BASE_URL=http://localhost:3000

# Gemini API key for the AI assistant ( /agent/chat ).
# Get one at https://aistudio.google.com/apikey
# If unset, /agent/chat returns a friendly "not configured" response.
GEMINI_API_KEY=

# Optional: override the Gemini model. Default is gemini-2.5-flash-lite.
# Free-tier daily request limits (as of 2026):
#   gemini-2.5-flash         5 RPM /  20 RPD   (very tight, easy to exhaust)
#   gemini-2.5-flash-lite   15 RPM / 500 RPD   (default — best for demos)
#   gemini-3.1-flash-lite   15 RPM / 500 RPD   (newer, similar limits)
#   gemini-2.5-pro           5 RPM /  25 RPD   (smartest, very tight)
# Check yours at https://ai.dev/rate-limit
# Opik (Comet) — LLM / agent observability for /agent/chat
# https://www.comet.com/docs/opik/
# Leave OPIK_API_KEY blank to disable (zero overhead).
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=conference-agent-portal
# Opik Cloud API base (required for hosted Opik):
OPIK_URL_OVERRIDE=https://www.comet.com/opik/api
